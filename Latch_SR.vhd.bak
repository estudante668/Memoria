library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity Latch_SR is
    port (
        S : in  std_logic; -- Set (Define como 1)
        R : in  std_logic; -- Reset (Define como 0)
        Q : out std_logic; -- Saída
        Qn: out std_logic  -- Saída invertida
    );
end Latch_SR;

architecture structural of Latch_SR is
    -- Sinais internos para permitir a realimentação (feedback)
    signal qi  : std_logic;
    signal qni : std_logic;
begin
    -- Implementação usando a lógica de portas NOR cruzadas
    -- Conforme a teoria do Harris (Figura 3.3 do livro)
    qi  <= R nor qni;
    qni <= S nor qi;

    -- Atribui os sinais internos às saídas
    Q  <= qi;
    Qn <= qni;
end structural;