library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity D_FlipFlop_Estrutural is
    Port (
        D   : in  STD_LOGIC;
        CLK : in  STD_LOGIC;
        Q   : out STD_LOGIC;
        Q_bar : out STD_LOGIC
    );
end D_FlipFlop_Estrutural;

architecture Structural of D_FlipFlop_Estrutural is
    -- Sinais internos para conectar os latches
    signal n1      : STD_LOGIC; -- Conexão entre mestre e escravo
    signal n1_bar  : STD_LOGIC; -- (Opcional)
    signal clk_inv : STD_LOGIC; -- Clock invertido para o mestre
begin

    -- 1. Inverte o clock para o primeiro Latch (Mestre)
    clk_inv <= not CLK;

    -- 2. Instancia o Latch Mestre (L1)
    -- Ele é transparente quando CLK = 0 (pois recebe clk_inv)
    Mestre: entity work.D_LATCH
        port map (
            D     => D,
            CLK   => clk_inv,
            Q     => n1,
            Q_bar => n1_bar
        );

    -- 3. Instancia o Latch Escravo (L2)
    -- Ele é transparente quando CLK = 1
    Escravo: entity work.D_LATCH
        port map (
            D     => n1,
            CLK   => CLK,
            Q     => Q,
            Q_bar => Q_bar
        );

end Structural;